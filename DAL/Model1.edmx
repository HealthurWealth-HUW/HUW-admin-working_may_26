          <EntitySet Name="Page1" EntityType="Self.Page1" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
[Page1].[Id] AS [Id], 
[Page1].[StateName] AS [StateName], 
[Page1].[PostOfficeNames] AS [PostOfficeNames], 
[Page1].[PinCode] AS [PinCode]
FROM [dbo].[Page1] AS [Page1]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="PincodeInfo" EntityType="Self.PincodeInfo" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
[PincodeInfo].[Id] AS [Id], 
[PincodeInfo].[StateName] AS [StateName], 
[PincodeInfo].[PostOfficeNames] AS [PostOfficeNames], 
[PincodeInfo].[PinCode] AS [PinCode], 
[PincodeInfo].[Status] AS [Status]
FROM [dbo].[PincodeInfo] AS [PincodeInfo]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="RetunOrders" EntityType="Self.RetunOrders" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
[RetunOrders].[PaymentTransactionId] AS [PaymentTransactionId], 
[RetunOrders].[ReturnDate] AS [ReturnDate], 
[RetunOrders].[ReturnReason] AS [ReturnReason], 
[RetunOrders].[ReturnAWB] AS [ReturnAWB]
FROM [dbo].[RetunOrders] AS [RetunOrders]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="Temp_File_Data" EntityType="Self.Temp_File_Data" store:Type="Tables" store:Schema="dbo">
            <DefiningQuery>SELECT 
[Temp_File_Data].[Id] AS [Id], 
[Temp_File_Data].[Order_id] AS [Order_id], 
[Temp_File_Data].[waybill_no] AS [waybill_no], 
[Temp_File_Data].[package_type] AS [package_type], 
[Temp_File_Data].[status] AS [status], 
[Temp_File_Data].[Sum] AS [Sum], 
[Temp_File_Data].[D_Pin] AS [D_Pin], 
[Temp_File_Data].[R_Pin] AS [R_Pin], 
[Temp_File_Data].[Item_Shipped] AS [Item_Shipped], 
[Temp_File_Data].[File_Name] AS [File_Name]
FROM [dbo].[Temp_File_Data] AS [Temp_File_Data]</DefiningQuery>
          </EntitySet>
